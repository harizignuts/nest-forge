{
  "name": "nest-forge",
  "version": "0.0.1",
  "description": "Modern NestJS + Prisma 7 Forge",
  "author": "Hari Malam",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": "^24.0.0"
  },
  "scripts": {
    "build": "pnpm prisma:generate && nest build",
    "build:swc": "pnpm prisma:generate && nest build --builder swc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma.config.ts\"",
    "start": "nest start --builder swc",
    "start:dev": "nest start --watch --builder swc",
    "start:debug": "nest start --debug --watch --builder swc",
    "start:docker": "pnpm prisma migrate deploy && node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "postinstall": "if [ \"$SKIP_PRISMA_GENERATE\" != \"true\" ]; then pnpm prisma:generate; fi",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:studio": "prisma studio",
    "test": "NODE_ENV=test jest",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:cov": "NODE_ENV=test jest --coverage",
    "test:debug": "NODE_ENV=test node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "fastify": "^5.8.4",
    "ioredis": "^5.10.1",
    "nest-winston": "^1.10.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@prisma/config": "^7.6.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.4.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "swc-loader": "^0.2.7",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "pnpm": {
    "overrides": {
      "picomatch": "^4.0.4",
      "path-to-regexp": "^8.4.0",
      "lodash": "^4.18.0",
      "nodemailer": "^8.0.4"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "chokidar"
      ],
      "allowedVersions": {
        "@swc/cli": "0.8.1",
        "class-validator": "0.15.1"
      }
    }
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@core/(.*)$": "<rootDir>/modules/core/$1",
      "^@api/(.*)$": "<rootDir>/modules/api/$1",
      "^@generated/(.*)$": "<rootDir>/../generated/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
